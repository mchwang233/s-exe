            key = match.group(1).strip()
            if key not in ctx:
                raise KeyError(f"unknown template variable: {key}")
            return str(ctx[key])
        return re.sub(r"@@\{\s*([A-Za-z_][A-Za-z0-9_]*)\s*\}@@", repl, self.text)


class SimpleEnvironment:
    def from_string(self, text: str) -> SimpleTemplate:
        return SimpleTemplate(text)


def make_env():
    if Environment is None:
        return SimpleEnvironment()
    return Environment(
        undefined=StrictUndefined,
        keep_trailing_newline=True,
        variable_start_string="@@{",
        variable_end_string="}@@",
        block_start_string="@%{",
        block_end_string="}%@",
        comment_start_string="@#{",
        comment_end_string="}#@",
    )


def snake_name(raw: str) -> str:
    name = raw.strip()
    if not name:
        raise ValueError("project name is empty")
    name = re.sub(r"[^A-Za-z0-9]+", "_", name)
    name = re.sub(r"_+", "_", name).strip("_").lower()
    if not name:
        raise ValueError(f"project name {raw!r} has no alphanumeric characters")
    if not re.match(r"^[a-z_]", name):
        name = f"p_{name}"
    return name


def is_skipped_rel(rel: str) -> bool:
    if rel == "sourceme":
        return True
    if rel in SKIP_DIRS:
        return True
    parts = rel.split("/")
    return any(part in SKIP_DIRS for part in parts) or Path(rel).suffix in SKIP_SUFFIXES


def rename_component(name: str, ctx: Dict[str, str]) -> str:
    out = name
    out = out.replace("my_", f"{ctx['prefix']}_")
    out = out.replace("MY_", f"{ctx['prefix_upper']}_")
    return out


def render_text(text: str, env, ctx: Dict[str, str]) -> str:
    rendered = env.from_string(text).render(**ctx)
    rendered = rendered.replace("my_", f"{ctx['prefix']}_")
    rendered = rendered.replace("MY_", f"{ctx['prefix_upper']}_")
    rendered = rendered.replace("my-", f"{ctx['prefix']}-")
    return rendered


def is_text_bytes(data: bytes) -> bool:
    if b"\x00" in data:
        return False
    try:
        data.decode("utf-8")
    except UnicodeDecodeError:
        return False
    return True


def safe_member_rel(name: str) -> Optional[Path]:
    cleaned = name.lstrip("./")
    if not cleaned:
        return None
    rel = Path(cleaned)
    if rel.is_absolute() or ".." in rel.parts:
        raise ValueError(f"unsafe template path in archive: {name}")
    return rel


def copy_from_src_dir(src_root: Path, dst_root: Path, env, ctx: Dict[str, str]) -> None:
    for src in sorted(src_root.rglob("*")):
        rel_posix = src.relative_to(src_root).as_posix()
        if is_skipped_rel(rel_posix):
            continue

        rel = src.relative_to(src_root)
        renamed_parts = [rename_component(part, ctx) for part in rel.parts]
        dst = dst_root.joinpath(*renamed_parts)

        if src.is_dir():
            dst.mkdir(parents=True, exist_ok=True)
            continue

        dst.parent.mkdir(parents=True, exist_ok=True)
        mode = stat.S_IMODE(src.stat().st_mode)
        data = src.read_bytes()
        if is_text_bytes(data):
            text = data.decode("utf-8")
            dst.write_text(render_text(text, env, ctx), encoding="utf-8")
        else:
            dst.write_bytes(data)
        os.chmod(dst, mode)


def copy_from_embedded(dst_root: Path, env, ctx: Dict[str, str]) -> None:
    raw = base64.b64decode(EMBEDDED_TEMPLATE_TGZ_B64.encode("ascii"))
    with tarfile.open(fileobj=io.BytesIO(raw), mode="r:gz") as tf:
        dirs = []
        files = []
        for member in tf.getmembers():
            rel = safe_member_rel(member.name)
            if rel is None:
                continue
            rel_posix = rel.as_posix()
            if is_skipped_rel(rel_posix):
                continue
            if member.isdir():
                dirs.append((rel, member))
            elif member.isfile():
                files.append((rel, member))

        for rel, member in sorted(dirs, key=lambda item: item[0].as_posix()):
            renamed = [rename_component(part, ctx) for part in rel.parts]
            dst = dst_root.joinpath(*renamed)
            dst.mkdir(parents=True, exist_ok=True)
            os.chmod(dst, stat.S_IMODE(member.mode) or 0o755)

        for rel, member in sorted(files, key=lambda item: item[0].as_posix()):
            renamed = [rename_component(part, ctx) for part in rel.parts]
            dst = dst_root.joinpath(*renamed)
            dst.parent.mkdir(parents=True, exist_ok=True)
            extracted = tf.extractfile(member)
            if extracted is None:
                continue
            data = extracted.read()
            if is_text_bytes(data):
                text = data.decode("utf-8")
                dst.write_text(render_text(text, env, ctx), encoding="utf-8")
            else:
                dst.write_bytes(data)
            os.chmod(dst, stat.S_IMODE(member.mode) or 0o644)


def write_root_files(project_dir: Path, env, ctx: Dict[str, str]) -> None:
    sourceme = project_dir / "sourceme"
    sourceme.write_text(env.from_string(ROOT_SOURCEME_TEMPLATE).render(**ctx), encoding="utf-8")
    sourceme.chmod(0o755)


def parse_args() -> argparse.Namespace:
    ap = argparse.ArgumentParser(
        description="Create an ASIC/verif project from the embedded s-exe template."
    )
    ap.add_argument("project", help="Project directory/name, e.g. usb or acme_dma")
    ap.add_argument(
        "--src",
        type=Path,
        default=None,
        help="Optional external s-exe directory. If omitted, use the embedded template.",
    )
    ap.add_argument(
        "--out-dir",
        type=Path,
        default=Path.cwd(),
        help="Parent directory for the new project (default: current directory)",
    )
    ap.add_argument(
        "--prefix",
        default=None,
        help="Replacement prefix for my_* names (default: sanitized project name)",
    )
    ap.add_argument(
        "--force",
        action="store_true",
        help="Overwrite an existing project directory.",
    )
    return ap.parse_args()


def main() -> int:
    args = parse_args()
    src_root = args.src.resolve() if args.src else None
    if src_root is not None and not src_root.is_dir():
        print(f"ERROR: source s-exe directory not found: {src_root}", file=sys.stderr)
        return 1

    project_name = snake_name(args.project)
    prefix = snake_name(args.prefix or project_name)
    project_dir = args.out_dir.resolve() / project_name

    if project_dir.exists():
        if not args.force:
            print(f"ERROR: output directory already exists: {project_dir}", file=sys.stderr)
            print("       Re-run with --force to overwrite it.", file=sys.stderr)
            return 1
        shutil.rmtree(project_dir)

    ctx = {
        "project_name": project_name,
        "prefix": prefix,
        "prefix_upper": prefix.upper(),
    }
    env = make_env()

    (project_dir / "asic").mkdir(parents=True)
    verif_dir = project_dir / "verif"
    verif_dir.mkdir()

    if src_root is None:
        copy_from_embedded(verif_dir, env, ctx)
    else:
        copy_from_src_dir(src_root, verif_dir, env, ctx)
    write_root_files(project_dir, env, ctx)

    print(f"created: {project_dir}")
    print(f"  asic:  {project_dir / 'asic'}")
    print(f"  verif: {verif_dir}")
    print(f"  source it with: source {project_dir / 'sourceme'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
