#!/usr/bin/env python3
"""
sexe - ssv simulation entry point

Usage (Python-style options):
    source sourceme                       # first source: adds tools/bin to PATH,
                                          # sets VCS_HOME / UVM_HOME / LM_LICENSE_FILE
    sexe build [--variant NAME]           # build the simv (default variant=baseline)
    sexe run --case CASE [--variant NAME] # run a case (default variant=baseline)
    sexe regress --cases CASE1 CASE2 ... [--variant NAME] [--parallel N]
                          # run cases in parallel; outputs go to
                          # sim/output/regress_<variant>_<YYYYMMDD_HHMMSS>/<case>/
    sexe list-builds                      # list all variants under sim/build/
    sexe gen [--file CFG]                 # manually run cfg2sv.py (normally unnecessary:
                                          #   sexe build's precomp hook does it)
    sexe clean [--variant NAME]           # rm -rf sim/output/<variant>/
    sexe --help                           # full help

Examples:
    sexe build --variant kdb
    sexe run --case smoke
    sexe run --case smoke --variant kdb
    sexe regress --cases smoke override_demo sub/test_inc

Requires: source sourceme first
(VCS_HOME / UVM_HOME / LM_LICENSE_FILE must all be set).
"""
import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

# Locate the project root from this script's path (not from cwd), so the
# tool works no matter where you invoke it from:
#   tools/bin/sexe -> tools/bin -> tools -> <proj_root>
SCRIPT_DIR = Path(__file__).resolve().parent
TOOLS_DIR = SCRIPT_DIR.parent
PROJECT_ROOT = TOOLS_DIR.parent
SIM_DIR = PROJECT_ROOT / "sim"
BUILD_DIR = SIM_DIR / "build"
OUTPUT_DIR = SIM_DIR / "output"


def env_check() -> None:
    """Verify VCS_HOME / UVM_HOME / LM_LICENSE_FILE are all set
    (equivalent to the env-check target in the old Makefile)."""
    missing = []
    for k in ("VCS_HOME", "UVM_HOME", "LM_LICENSE_FILE"):
        if not os.environ.get(k):
            missing.append(k)
    if missing:
        print(f"ERROR: env vars not set: {missing}")
        print(f"       Run: source sourceme (or fix {PROJECT_ROOT}/sourceme)")
        sys.exit(1)
    vcs = Path(os.environ["VCS_HOME"]) / "bin" / "vcs"
    if not vcs.is_file():
        print(f"ERROR: $VCS_HOME/bin/vcs not found ({vcs})")
        print(f"       Edit {PROJECT_ROOT}/sourceme to fix path")
        sys.exit(1)


def list_build_variants() -> list:
    if not BUILD_DIR.is_dir():
        return []
    return sorted(p.stem for p in BUILD_DIR.glob("*.cmd"))


def cmd_build(args) -> int:
    build = args.variant
    simv_dir = OUTPUT_DIR / build
    simv_bin = simv_dir / "simv"
    build_cmd = BUILD_DIR / f"{build}.cmd"

    if not build_cmd.is_file():
        print(f"ERROR: no build cmd: {build_cmd}")
        avail = list_build_variants()
        if avail:
            print(f"(available: {avail})")
        else:
            print(f"(no .cmd files in {BUILD_DIR})")
        return 1

    print(f"[sexe] build: {build_cmd} -> {simv_bin}")
    return subprocess.run(
        ["python3", str(PROJECT_ROOT / "tools" / "run_case.py"), str(build_cmd),
         "--out", str(simv_bin), "--build-only"],
        cwd=str(PROJECT_ROOT),
    ).returncode


def cmd_run(args) -> int:
    build = args.variant
    case = args.case
    simv_dir = OUTPUT_DIR / build
    simv_bin = simv_dir / "simv"

    # Look up the case .cmd: try cases/<case> first, then cases/<case>.cmd.
    case_cmd = PROJECT_ROOT / "cases" / case
    if not case_cmd.is_file():
        case_cmd = case_cmd.with_suffix(".cmd")
    if not case_cmd.is_file():
        print(f"ERROR: case {case} (or {case}.cmd) not found under cases/")
        return 1

    # Auto-build simv if it is missing.
    if not simv_bin.is_file():
        print(f"[sexe] {simv_bin} missing, building {build}...")
        rc = subprocess.run(
            [sys.executable, __file__, "build", "--variant", build],
            cwd=str(PROJECT_ROOT),
        ).returncode
        if rc != 0:
            return rc

    print(f"[sexe] run case {case} (simv={simv_bin})")
    cmd = ["python3", str(PROJECT_ROOT / "tools" / "run_case.py"), str(case_cmd),
           "--baseline", str(simv_bin)]
    if getattr(args, "case_run_dir", None):
        cmd.extend(["--case-run-dir", args.case_run_dir])
    return subprocess.run(cmd, cwd=str(PROJECT_ROOT)).returncode


def cmd_regress(args) -> int:
    import time
    from concurrent.futures import ThreadPoolExecutor, as_completed

    cases = args.cases
    build = args.variant
    parallel = getattr(args, "parallel", None)

    # Consolidate all case outputs under one directory:
    #   sim/output/regress_<variant>_<YYYYMMDD_HHMMSS>/<case>/
    timestamp = time.strftime("%Y%m%d_%H%M%S")
    regress_dir = OUTPUT_DIR / f"regress_{build}_{timestamp}"
    regress_dir.mkdir(parents=True, exist_ok=True)
    print(f"[sexe] regress dir: {regress_dir}")
    print(f"[sexe] cases ({len(cases)}): {', '.join(cases)}")

    if parallel is None or parallel <= 0:
        parallel = min(len(cases), 8)
    print(f"[sexe] parallel workers: {parallel}")

    def run_one(case: str):
        case_dir = regress_dir / case
        case_dir.mkdir(parents=True, exist_ok=True)
        cmd = [
            sys.executable, __file__, "run",
            "--case", case, "--variant", build,
            "--case-run-dir", str(case_dir),
        ]
        t0 = time.time()
        rc = subprocess.run(cmd, cwd=str(PROJECT_ROOT)).returncode
        dt = time.time() - t0
        return case, rc, case_dir, dt

    results = {}
    with ThreadPoolExecutor(max_workers=parallel) as pool:
        futures = {pool.submit(run_one, c): c for c in cases}
        for fut in as_completed(futures):
            case, rc, case_dir, dt = fut.result()
            results[case] = (rc, case_dir, dt)

    # Summary (in original case order so output is deterministic)
    print(f"\n=== regress summary ({len(cases)} cases, dir={regress_dir}) ===")
    failed = []
    for c in cases:
        rc, cdir, dt = results[c]
        status = "PASS" if rc == 0 else f"FAIL (rc={rc})"
        print(f"  [{status}] {c:<30s} {dt:6.1f}s  {cdir}")
        if rc != 0:
            failed.append((c, rc))

    # Write regress.log (per-case summary)
    log_path = regress_dir / "regress.log"
    with open(log_path, "w") as flog:
        flog.write(f"regress: variant={build} ts={timestamp} cases={len(cases)}\n")
        flog.write(f"dir: {regress_dir}\n\n")
        for c in cases:
            rc, cdir, dt = results[c]
            flog.write(f"[{'PASS' if rc == 0 else 'FAIL'}] {c} rc={rc} dt={dt:.1f}s {cdir}\n")
    print(f"[sexe] regress.log: {log_path}")

    if failed:
        print(f"\nFAILED: {len(failed)} cases")
        return 1
    print(f"\nAll {len(cases)} cases PASSED.")
    return 0


def cmd_list_builds(args) -> int:
    for b in list_build_variants():
        print(b)
    return 0


def cmd_gen(args) -> int:
    cmd = ["python3", str(PROJECT_ROOT / "tools" / "cfg2sv.py"),
           "--cfg-dir", str(PROJECT_ROOT / "cfg"),
           "--root-class", "ssv_root_cfg"]
    if getattr(args, "file", None):
        cmd.extend(["--file", args.file])
    return subprocess.run(cmd, cwd=str(PROJECT_ROOT)).returncode


def cmd_clean(args) -> int:
    build = args.variant
    simv_dir = OUTPUT_DIR / build
    if simv_dir.is_dir():
        print(f"[sexe] rm -rf {simv_dir}")
        shutil.rmtree(simv_dir)
    else:
        print(f"[sexe] {simv_dir} not exist, skip")
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="sexe",
        description="ssv simulation entry point",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="command")

    # build [--variant NAME]
    p_build = sub.add_parser("build", help="Build a simv variant (default baseline).")
    p_build.add_argument("--variant", default="baseline",
                        help="Variant name (corresponds to sim/build/<name>.cmd;"
                             " default: baseline).")

    # run --case CASE [--variant NAME]
    p_run = sub.add_parser("run", help="Run a single case.")
    p_run.add_argument("--case", required=True,
                      help="Case name (may include a sub-directory, e.g. sub/foo).")
    p_run.add_argument("--variant", default="baseline",
                      help="Variant name (default: baseline).")
    p_run.add_argument("--case-run-dir", default=None,
                      help="Override the case run dir "
                           "(default: sim/<variant>/run/<case>/). "
                           "Used by `sexe regress`.")

    # regress --cases CASE1 CASE2 ... [--variant NAME]
    p_regress = sub.add_parser("regress", help="Run a batch of cases in parallel under one regress dir.")
    p_regress.add_argument("--cases", required=True, nargs="+",
                          help="Case name list (space-separated).")
    p_regress.add_argument("--variant", default="baseline",
                          help="Variant name (default: baseline).")
    p_regress.add_argument("--parallel", type=int, default=None,
                          help="Max parallel simv processes (default: min(num_cases, 8)).")

    sub.add_parser("list-builds", help="List all variants under sim/build/.")
    p_gen = sub.add_parser("gen",
                          help="Manually run cfg2sv.py (normally unnecessary;"
                               " sexe build's precomp hook does it).")
    p_gen.add_argument("--file",
                       help="Convert only this one .cfg (relative to cfg/);"
                            " does not regenerate ssv_cfg_pkg.sv or all.cmd.")

    # clean [--variant NAME]
    p_clean = sub.add_parser("clean", help="Remove sim/output/<variant>/.")
    p_clean.add_argument("--variant", default="baseline",
                        help="Variant name (default: baseline).")

    return p


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 0

    env_check()

    dispatch = {
        "build": cmd_build,
        "run": cmd_run,
        "regress": cmd_regress,
        "list-builds": cmd_list_builds,
        "gen": cmd_gen,
        "clean": cmd_clean,
    }
    return dispatch[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
